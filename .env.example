DATABASE_URL=postgresql+asyncpg://skillsclaw:skillsclaw@localhost:5432/skillsclaw
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=your-secret-key-here-change-in-production
# MinIO (local dev) — these match the docker-compose defaults, no changes needed
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=skillsclaw
S3_SECRET_KEY=skillsclaw
S3_BUCKET_NAME=skillsclaw-videos
S3_PUBLIC_URL=http://localhost:9000

# Text LLM provider used for workflow synthesis + SKILL.md generation
# Options: anthropic | openai | gemini | openrouter | ollama
LLM_PROVIDER=ollama

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_TEXT_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_TEXT_MODEL=gpt-4o-mini

# Gemini
GOOGLE_API_KEY=your-google-api-key
GEMINI_TEXT_MODEL=gemini-1.5-flash

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TEXT_MODEL=openai/gpt-4o-mini

# Ollama fallback (local or remote)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEXT_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_SECONDS=600
OLLAMA_MAX_RETRIES=2

# Shared timeout/retry for remote providers
LLM_REQUEST_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=2


GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
RESEND_API_KEY=re_your-resend-api-key
FRONTEND_URL=http://localhost:5173

# Set to true locally to bypass all auth — a fixed "Dev User" is used automatically
DEV_MODE=false
